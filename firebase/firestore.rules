rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isUser(userId);
    }

    match /listings/{listingId} {
      allow read: if signedIn();
      allow create: if isUser(request.resource.data.ownerId);
      allow update: if isUser(resource.data.ownerId) || isUser(resource.data.claimedBy);
      allow delete: if isUser(resource.data.ownerId);
    }

    match /tradeOffers/{offerId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.requesterId
          || request.auth.uid == resource.data.listingOwnerId);
      allow create: if isUser(request.resource.data.requesterId);
      allow update: if signedIn()
        && (request.auth.uid == resource.data.requesterId
          || request.auth.uid == resource.data.listingOwnerId);
    }

    match /ratings/{ratingId} {
      allow read: if signedIn();
      allow create: if isUser(request.resource.data.fromUserId);
      allow update, delete: if false;
    }
  }
}
